# MongoDB connection string
MONGODB_URI="mongodb://localhost:27017/mentora_db"
# For MongoDB Atlas:
# MONGODB_URI="mongodb+srv://<user>:<password>@cluster.mongodb.net/mentora_db"

# JWT
